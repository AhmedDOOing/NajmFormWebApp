# Copy this file to .env.local. Do not commit .env.local.

# Required whenever the webhook is reachable from the internet. Use a long,
# random value and configure the identical value in Hamsa as a Bearer token.
HAMSA_WEBHOOK_SECRET=replace-with-a-long-random-secret

# Optional. Used as a fallback for generated links and by npm run simulate:call.
# When Hamsa posts through ngrok, the app derives the public URL from the
# incoming request, so this does not need to be set for real Hamsa calls.
# NAJM_BASE_URL=https://your-domain.ngrok-free.app

# Optional: enables live photo analysis. Without it, the UI uses its demo stub.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: enables real SMS delivery. All three values are required together.
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM=+1...
